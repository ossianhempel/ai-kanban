# Production .env for a self-hosted instance.
# Copy to /opt/ai-kanban/.env on the server (never commit real secrets).

NODE_ENV=production
PORT=3000

AIKANBAN_DATA_DIR=/app/data
DATABASE_URL=file:/app/data/pglite

# Pre-built image (pull-based deploy only — omit for git-clone install)
# AIKANBAN_IMAGE=ghcr.io/YOUR_GITHUB_USER/ai-kanban:latest

# openssl rand -base64 32
BETTER_AUTH_SECRET=replace-me

# Must match the URL users open in the browser (HTTPS)
BETTER_AUTH_URL=https://kanban.yourcompany.com
WEB_ORIGIN=https://kanban.yourcompany.com

# openssl rand -hex 16 — same value in ADO service hook ?token=
AZURE_DEVOPS_WEBHOOK_SECRET=replace-me

# Sign-up: closed by default in production (first account still works for bootstrap)
ALLOW_PUBLIC_SIGNUP=false
SIGNUP_ALLOWED_DOMAINS=yourcompany.com

# Microsoft Entra ID SSO (see docs/deploy/microsoft-sso.md)
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=
AUTH_EMAIL_PASSWORD_ENABLED=false
AUTH_PROVIDERS=microsoft

# Optional: GitHub / Google OAuth
# GITHUB_OAUTH_CLIENT_ID=
# GITHUB_OAUTH_CLIENT_SECRET=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Optional
# GITHUB_WEBHOOK_SECRET=
# AIKANBAN_API_TOKEN=  # Bearer token for CLI/MCP when no browser session (openssl rand -hex 32)
