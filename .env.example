# Server
PORT=3000
NODE_ENV=development

# Data directory (PGlite files live at $AIKANBAN_DATA_DIR/pglite)
AIKANBAN_DATA_DIR=./data

# Database URL — file: for PGlite, postgres:// for external Postgres (future)
DATABASE_URL=file:./data/pglite

# Auth (generate with: openssl rand -base64 32)
BETTER_AUTH_SECRET=dev-only-secret-change-me-in-production-32chars
# Public URL for auth callbacks — use Vite dev origin when proxying /api
BETTER_AUTH_URL=http://localhost:5180
WEB_ORIGIN=http://localhost:5180

# Web dev server port (change if 5180 is taken)
WEB_DEV_PORT=5180

# Optional client override (defaults to same origin)
# VITE_BETTER_AUTH_URL=http://localhost:5180

# CLI / MCP clients — Bearer token acts as first admin when set (see AGENTS.md)
# openssl rand -hex 32
AIKANBAN_API_TOKEN=

# Production pull deploy — set on the server (see docs/deploy/examples/env.production.example)
# AIKANBAN_IMAGE=ghcr.io/YOUR_GITHUB_USER/ai-kanban:latest

# Sign-up policy (production: keep public sign-up off)
# ALLOW_PUBLIC_SIGNUP=false
# SIGNUP_ALLOWED_DOMAINS=yourcompany.com
# SIGNUP_ALLOWED_EMAILS=contractor@example.com,another@yourcompany.com

# Auth providers (optional — enable by setting client id + secret)
# AUTH_EMAIL_PASSWORD_ENABLED=true
# AUTH_PROVIDERS=microsoft,github,google
# MICROSOFT_CLIENT_ID=
# MICROSOFT_CLIENT_SECRET=
# MICROSOFT_TENANT_ID=
# GITHUB_OAUTH_CLIENT_ID=
# GITHUB_OAUTH_CLIENT_SECRET=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# GitHub webhooks (set in repo webhook secret; skip verification if unset in dev)
GITHUB_WEBHOOK_SECRET=

# Azure DevOps service hooks (append ?token=... to webhook URL; skip verification if unset in dev)
AZURE_DEVOPS_WEBHOOK_SECRET=
